# ferryman — required environment variables.
#
# Copy to `.env` and fill in real values, OR export these in your shell.
# `.env` is gitignored; never commit real keys. Config files reference these
# by NAME only (see ferryman/config.toml → apiKeyEnv).

# z.ai GLM — powers the `zai-glm` provider entry (default provider).
ZAI_API_KEY=...

# Google Gemini — powers the `gemini` provider entry (OpenAI-compatible endpoint).
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=...

# DeepInfra — powers the `hf-llama` provider entry (Llama 3.1 70B, OpenAI-compatible).
# Get a key at https://deepinfra.com/dashboards/api_keys
DEEPINFRA_API_KEY=...

# Judge model — the LLM-as-judge for the eval harness's subjective scorer layer.
# Defaults to OpenAI gpt-4o-mini (family `gpt`, which has no overlap with the
# evaluated providers glm/gemini/meta, so family-exclusion never skips a row).
# Only needed for `run_scorecard.py --judge`. Get a key at https://platform.openai.com/api_keys
JUDGE_API_KEY=...
# Optional overrides (defaults shown):
# JUDGE_BASE_URL=https://api.openai.com/v1
# JUDGE_MODEL=gpt-4o-mini
