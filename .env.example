# ferryman — required environment variables.
#
# Copy to `.env` and fill in real values, OR export these in your shell.
# `.env` is gitignored; never commit real keys. Config files reference these
# by NAME only (see ferryman/config.toml → apiKeyEnv).

# Inbound auth for the HTTP channel (`ferry serve`). Callers must present this
# as a bearer token on POST /invoke. Distinct from the provider keys below —
# those are outbound (how ferry calls the LLM); this is who may call ferry.
# Generate one with, e.g., `openssl rand -hex 32`. Without it `ferry serve`
# refuses to start.
FERRY_HTTP_TOKEN=...

# z.ai GLM — powers the `zai-glm` provider entry (default provider).
ZAI_API_KEY=...

# Google Gemini — powers the `gemini` provider entry (OpenAI-compatible endpoint).
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=...

# DeepInfra — powers the `hf-llama` provider entry (Llama 3.1 8B, OpenAI-compatible).
# Get a key at https://deepinfra.com/dashboards/api_keys
DEEPINFRA_API_KEY=...
