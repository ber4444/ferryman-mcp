# ferryman — required environment variables.
#
# Copy to `.env` and fill in real values, OR export these in your shell.
# `.env` is gitignored; never commit real keys. Config files reference these
# by NAME only (see ferryman/config.toml → apiKeyEnv).

# Anthropic (Claude) — powers the `anthropic` provider entry.
ANTHROPIC_API_KEY=sk-ant-...

# z.ai GLM — powers the `zai-glm` provider entry (OpenAI-compatible endpoint).
# Credits on this plan expire 2026-07-19; afterwards repoint config.toml to a
# local Ollama/vLLM URL or a hosted OpenAI-compatible endpoint.
ZAI_API_KEY=...

# Google Gemini — powers the `gemini` provider entry (OpenAI-compatible endpoint).
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=...

# Perplexity Sonar — powers the `perplexity` provider entry (web-grounded, OpenAI-compatible).
# Get a key at https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=...
